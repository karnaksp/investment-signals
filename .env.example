TINVEST_TOKEN=replace-with-your-token
TINVEST_USE_SANDBOX=false
TINVEST_APP_NAME=tinvest-signal-engine

HOST_KAFKA_PORT=39092
HOST_REDPANDA_METRICS_PORT=39644
HOST_REDPANDA_CONSOLE_PORT=38080
HOST_POSTGRES_PORT=35432
HOST_API_PORT=38000

KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_HOST_BOOTSTRAP_SERVERS=localhost:39092
KAFKA_RAW_TOPIC=marketdata.raw
KAFKA_SIGNAL_TOPIC=marketdata.signals
KAFKA_CONSUMER_GROUP=signal-detector
KAFKA_AUTO_OFFSET_RESET=latest
LOCAL_NOTIFIER_CONSUMER_GROUP=local-notifier
LOCAL_NOTIFICATION_DURATION_SECONDS=5

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=signal_engine
POSTGRES_USERNAME=signal_engine
POSTGRES_PASSWORD=signal_engine
POSTGRES_TABLE=market_signals
POSTGRES_STARTUP_TIMEOUT_SECONDS=90
POSTGRES_STARTUP_CHECK_INTERVAL_SECONDS=2

API_HOST=0.0.0.0
API_PORT=8000

ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
LOG_LEVEL=INFO

# Интервал опроса mtime conf/*.yaml для горячей подхватки (сек). 0 — только при рестарте контейнера.
CONFIG_RELOAD_INTERVAL_SECONDS=10

DETECTORS_OVERRIDES_CONFIG=conf/detectors.overrides.yaml
THRESHOLD_RECALC_INTERVAL_HOURS=24
THRESHOLD_LOOKBACK_DAYS=7
# Итоговый порог = среднее почасовое отклонение (bps) * multiplier
THRESHOLD_HOURLY_DEVIATION_MULTIPLIER=1.0
